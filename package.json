{
  "name": "ingest-ai",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start:minio": "minio server ~/minio-data --console-address ':9001'",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:worker\" \"pnpm dev:web\"",
    "dev:api": "ts-node-dev -r dotenv/config -r reflect-metadata --respawn --transpile-only apps/api/src/main.ts",
    "dev:worker": "ts-node-dev -r dotenv/config apps/worker/src/document.worker.ts",
    "dev:web": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "build:shared": "pnpm --filter @ingest-ai/shared build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "prisma": "^7.6.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.2"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bullmq": "^5.71.1",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "minio": "^8.0.7",
    "openai": "^6.33.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.20.0"
  }
}